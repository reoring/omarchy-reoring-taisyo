#!/usr/bin/env python3

import argparse
import os
import shutil
import signal
import subprocess
import sys

import dbus
import dbus.mainloop.glib
import dbus.service
from gi.repository import GLib


BLUEZ = "org.bluez"
AGENT_MGR_PATH = "/org/bluez"
AGENT_MGR_IFACE = "org.bluez.AgentManager1"
AGENT_IFACE = "org.bluez.Agent1"
PROPS_IFACE = "org.freedesktop.DBus.Properties"


class Rejected(dbus.DBusException):
    _dbus_error_name = "org.bluez.Error.Rejected"


def _notify(title: str, body: str) -> None:
    if shutil.which("notify-send") is None:
        return
    try:
        subprocess.run(["notify-send", title, body], check=False)
    except Exception:
        return


def _device_label(bus: dbus.bus.BusConnection, device_path: str) -> str:
    try:
        props = dbus.Interface(bus.get_object(BLUEZ, device_path), PROPS_IFACE)
        addr = str(props.Get("org.bluez.Device1", "Address"))
        name = str(props.Get("org.bluez.Device1", "Alias"))
        return f"{name} ({addr})"
    except Exception:
        return device_path


def _zenity_entry(title: str, text: str) -> str:
    if shutil.which("zenity") is None:
        raise Rejected("No UI to ask for input")

    proc = subprocess.run(
        ["zenity", "--entry", f"--title={title}", f"--text={text}"],
        capture_output=True,
        text=True,
    )
    if proc.returncode != 0:
        raise Rejected("Canceled")
    return (proc.stdout or "").strip()


class Agent(dbus.service.Object):
    def __init__(self, bus: dbus.bus.BusConnection, path: str) -> None:
        super().__init__(bus, path)
        self._bus = bus

    @dbus.service.method(AGENT_IFACE, in_signature="", out_signature="")
    def Release(self) -> None:
        _notify("Bluetooth", "Pairing agent released")

    @dbus.service.method(AGENT_IFACE, in_signature="o", out_signature="s")
    def RequestPinCode(self, device: str) -> str:
        label = _device_label(self._bus, device)
        _notify("Bluetooth", f"PIN code required for {label}")
        env = os.environ.get("BT_AGENT_PINCODE", "").strip()
        if env:
            return env
        return _zenity_entry("Bluetooth pairing", f"Enter PIN code for {label}:")

    @dbus.service.method(AGENT_IFACE, in_signature="o", out_signature="u")
    def RequestPasskey(self, device: str) -> dbus.UInt32:
        label = _device_label(self._bus, device)
        _notify("Bluetooth", f"Passkey required for {label}")
        env = os.environ.get("BT_AGENT_PASSKEY", "").strip()
        if env:
            try:
                n = int(env, 10)
            except Exception as e:
                raise Rejected("Invalid BT_AGENT_PASSKEY") from e
            if n < 0 or n > 999999:
                raise Rejected("Passkey out of range")
            return dbus.UInt32(n)

        s = _zenity_entry("Bluetooth pairing", f"Enter passkey for {label} (0-999999):")
        try:
            n = int(s, 10)
        except Exception as e:
            raise Rejected("Invalid passkey") from e
        if n < 0 or n > 999999:
            raise Rejected("Passkey out of range")
        return dbus.UInt32(n)

    @dbus.service.method(AGENT_IFACE, in_signature="os", out_signature="")
    def DisplayPinCode(self, device: str, pincode: str) -> None:
        label = _device_label(self._bus, device)
        _notify("Bluetooth", f"PIN for {label}: {pincode}\nType it on the device and press Enter")

    @dbus.service.method(AGENT_IFACE, in_signature="ouq", out_signature="")
    def DisplayPasskey(self, device: str, passkey: dbus.UInt32, entered: dbus.UInt16) -> None:
        label = _device_label(self._bus, device)
        pk = int(passkey)
        ent = int(entered)
        _notify("Bluetooth", f"Passkey for {label}: {pk:06d}\nEntered: {ent}/6")

    @dbus.service.method(AGENT_IFACE, in_signature="ou", out_signature="")
    def RequestConfirmation(self, device: str, passkey: dbus.UInt32) -> None:
        label = _device_label(self._bus, device)
        pk = int(passkey)
        _notify("Bluetooth", f"Confirm passkey for {label}: {pk:06d}\nAuto-accept")
        return

    @dbus.service.method(AGENT_IFACE, in_signature="o", out_signature="")
    def RequestAuthorization(self, device: str) -> None:
        label = _device_label(self._bus, device)
        _notify("Bluetooth", f"Authorize {label}\nAuto-accept")
        return

    @dbus.service.method(AGENT_IFACE, in_signature="os", out_signature="")
    def AuthorizeService(self, device: str, uuid: str) -> None:
        # Auto-authorize service connections.
        return

    @dbus.service.method(AGENT_IFACE, in_signature="", out_signature="")
    def Cancel(self) -> None:
        _notify("Bluetooth", "Pairing canceled")


def main() -> int:
    parser = argparse.ArgumentParser(add_help=True)
    parser.add_argument("--timeout", type=int, default=120)
    parser.add_argument("--capability", type=str, default="DisplayYesNo")
    args = parser.parse_args()

    dbus.mainloop.glib.DBusGMainLoop(set_as_default=True)
    bus = dbus.SystemBus()
    agent_path = f"/reoring/bluez_agent_auto_{os.getpid()}"

    Agent(bus, agent_path)

    mgr = dbus.Interface(bus.get_object(BLUEZ, AGENT_MGR_PATH), AGENT_MGR_IFACE)
    mgr.RegisterAgent(agent_path, args.capability)
    mgr.RequestDefaultAgent(agent_path)

    sys.stdout.write("READY\n")
    sys.stdout.flush()

    loop = GLib.MainLoop()

    def _quit(*_a: object) -> None:
        try:
            loop.quit()
        except Exception:
            pass

    signal.signal(signal.SIGINT, _quit)
    signal.signal(signal.SIGTERM, _quit)

    if args.timeout > 0:
        GLib.timeout_add_seconds(args.timeout, lambda: (_quit(), False)[1])

    try:
        loop.run()
    finally:
        try:
            mgr.UnregisterAgent(agent_path)
        except Exception:
            pass

    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except dbus.DBusException as e:
        sys.stderr.write(f"bluez-agent-auto: {e}\n")
        raise
